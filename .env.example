# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# See README.md and SECURITY.md.

# Server-only: NVIDIA API (used by /api/generate-plan only)
NVIDIA_API_KEY=
# Optional override
# NVIDIA_MODEL=nvidia/nvidia-nemotron-nano-9b-v2

# Public (embedded in browser bundle for Supabase Auth — use anon key only, never service_role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
